# ===== Tab 1: Script (REQUIRED for the live feature) =====
# Pays for script generation via the strong model (Anthropic).
# Alternatively, set this from the web UI: open the Settings tab and paste your
# key — it's saved to ~/.marcus-krispy/secrets.json (0600), no file editing.
# Precedence is env-first: if BOTH are set, this env var wins.
ANTHROPIC_API_KEY=

# Optional: swap the strong script model without code changes.
# Default is claude-sonnet-4-6. Any Anthropic model id works (e.g. claude-opus-4-8).
SCRIPT_MODEL=

# Cheap mechanical steps (outlines, tags, cleanup). Unused in Phase-1 but wired.
GEMINI_API_KEY=
# Optional override; default gemini-2.5-flash.
MECHANICAL_MODEL=

# Engine selector: "pipeline" (default — research → draft → fact-check) or
# "single-shot" (legacy fallback). Leave empty to use the default pipeline.
# SCRIPT_ENGINE=

# Optional login gate (mirror Dave). Empty = no login locally; REQUIRED on any deploy.
APP_PASSWORD=

# ===== Tab 2: Competitors/Outliers (SEAM — not yet used) =====
# YouTube Data API v3 key (public data). Leave empty until Tab 2 is built.
YOUTUBE_DATA_API_KEY=

# ===== Tab 3: My Analytics (SEAM — not yet used) =====
# Google OAuth 2.0 "bring your own client" (private retention/analytics).
# Leave empty until Tab 3 is built.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public origin for the OAuth redirect (…/api/youtube/oauth/callback) behind a proxy.
PUBLIC_BASE_URL=
